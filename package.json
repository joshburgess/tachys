{
  "name": "phasm",
  "version": "0.0.1",
  "description": "A high-performance virtual DOM library optimized for V8",
  "license": "MIT",
  "author": "Josh Burgess",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./jsx-runtime": {
      "import": {
        "types": "./dist/jsx-runtime.d.ts",
        "default": "./dist/jsx-runtime.js"
      },
      "require": {
        "types": "./dist/jsx-runtime.d.cts",
        "default": "./dist/jsx-runtime.cjs"
      }
    },
    "./jsx-dev-runtime": {
      "import": {
        "types": "./dist/jsx-dev-runtime.d.ts",
        "default": "./dist/jsx-dev-runtime.js"
      },
      "require": {
        "types": "./dist/jsx-dev-runtime.d.cts",
        "default": "./dist/jsx-dev-runtime.cjs"
      }
    },
    "./compat": {
      "import": {
        "types": "./dist/compat.d.ts",
        "default": "./dist/compat.js"
      },
      "require": {
        "types": "./dist/compat.d.cts",
        "default": "./dist/compat.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "rm -rf dist && rollup -c rollup.config.mjs && tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.cts && cp dist/jsx-runtime.d.ts dist/jsx-runtime.d.cts && cp dist/jsx-dev-runtime.d.ts dist/jsx-dev-runtime.d.cts && cp dist/compat.d.ts dist/compat.d.cts && cp dist/server.d.ts dist/server.d.cts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "rm -rf dist",
    "bench": "vitest bench --run",
    "bench:watch": "vitest bench",
    "bench:browser": "pnpm run build && npx playwright test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@swc/core": "^1.9.0",
    "@vitest/coverage-v8": "^3.2.4",
    "fast-check": "^4.6.0",
    "inferno": "^8.2.3",
    "inferno-create-element": "^8.2.3",
    "jsdom": "^26.0.0",
    "rollup": "^4.28.0",
    "rollup-plugin-swc3": "^0.12.1",
    "typescript": "^5.7.2",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4"
  }
}
