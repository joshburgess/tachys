{
  "name": "tachys",
  "version": "0.1.0",
  "description": "A high-performance virtual DOM library optimized for V8",
  "license": "MIT OR Apache-2.0",
  "author": "Josh Burgess",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshburgess/tachys.git"
  },
  "homepage": "https://github.com/joshburgess/tachys",
  "bugs": {
    "url": "https://github.com/joshburgess/tachys/issues"
  },
  "keywords": [
    "virtual-dom",
    "vdom",
    "dom",
    "ui",
    "jsx",
    "react",
    "hooks",
    "ssr",
    "hydration",
    "suspense",
    "performance"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./jsx-runtime": {
      "import": {
        "types": "./dist/jsx-runtime.d.ts",
        "default": "./dist/jsx-runtime.js"
      },
      "require": {
        "types": "./dist/jsx-runtime.d.cts",
        "default": "./dist/jsx-runtime.cjs"
      }
    },
    "./jsx-dev-runtime": {
      "import": {
        "types": "./dist/jsx-dev-runtime.d.ts",
        "default": "./dist/jsx-dev-runtime.js"
      },
      "require": {
        "types": "./dist/jsx-dev-runtime.d.cts",
        "default": "./dist/jsx-dev-runtime.cjs"
      }
    },
    "./compat": {
      "import": {
        "types": "./dist/compat.d.ts",
        "default": "./dist/compat.js"
      },
      "require": {
        "types": "./dist/compat.d.cts",
        "default": "./dist/compat.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    },
    "./tags": {
      "import": {
        "types": "./dist/tags.d.ts",
        "default": "./dist/tags.js"
      },
      "require": {
        "types": "./dist/tags.d.cts",
        "default": "./dist/tags.cjs"
      }
    },
    "./compiled": {
      "import": {
        "types": "./dist/compiled.d.ts",
        "default": "./dist/compiled.js"
      },
      "require": {
        "types": "./dist/compiled.d.cts",
        "default": "./dist/compiled.cjs"
      }
    },
    "./hydrate": {
      "import": {
        "types": "./dist/hydrate.d.ts",
        "default": "./dist/hydrate.js"
      },
      "require": {
        "types": "./dist/hydrate.d.cts",
        "default": "./dist/hydrate.cjs"
      }
    },
    "./sync": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/sync.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/sync.cjs"
      }
    },
    "./sync-core": {
      "import": {
        "types": "./dist/sync-core.d.ts",
        "default": "./dist/sync-core.js"
      },
      "require": {
        "types": "./dist/sync-core.d.cts",
        "default": "./dist/sync-core.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/compat.d.ts",
        "default": "./dist/compat.js"
      },
      "require": {
        "types": "./dist/compat.d.cts",
        "default": "./dist/compat.cjs"
      }
    }
  },
  "files": [
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.cjs",
    "dist/*.cjs.map",
    "dist/*.d.ts",
    "dist/*.d.cts",
    "dist/*.d.ts.map",
    "dist/*.d.cts.map",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test",
    "build": "rm -rf dist && rollup -c rollup.config.mjs && tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.cts && cp dist/jsx-runtime.d.ts dist/jsx-runtime.d.cts && cp dist/jsx-dev-runtime.d.ts dist/jsx-dev-runtime.d.cts && cp dist/compat.d.ts dist/compat.d.cts && cp dist/server.d.ts dist/server.d.cts && cp dist/tags.d.ts dist/tags.d.cts && cp dist/compiled.d.ts dist/compiled.d.cts && cp dist/sync-core.d.ts dist/sync-core.d.cts && cp dist/hydrate-root.d.ts dist/hydrate.d.ts && cp dist/hydrate-root.d.ts dist/hydrate.d.cts && cp dist/index.d.ts.map dist/index.d.cts.map && cp dist/jsx-runtime.d.ts.map dist/jsx-runtime.d.cts.map && cp dist/jsx-dev-runtime.d.ts.map dist/jsx-dev-runtime.d.cts.map && cp dist/compat.d.ts.map dist/compat.d.cts.map && cp dist/server.d.ts.map dist/server.d.cts.map && cp dist/tags.d.ts.map dist/tags.d.cts.map && cp dist/compiled.d.ts.map dist/compiled.d.cts.map && cp dist/sync-core.d.ts.map dist/sync-core.d.cts.map && cp dist/hydrate-root.d.ts.map dist/hydrate.d.ts.map && cp dist/hydrate-root.d.ts.map dist/hydrate.d.cts.map",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "rm -rf dist",
    "bench": "vitest bench --run",
    "bench:watch": "vitest bench",
    "bench:browser": "pnpm run build && npx playwright test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@swc/core": "^1.9.0",
    "@vitest/coverage-v8": "^3.2.4",
    "fast-check": "^4.6.0",
    "inferno": "^8.2.3",
    "inferno-create-element": "^8.2.3",
    "jsdom": "^26.0.0",
    "rollup": "^4.28.0",
    "rollup-plugin-swc3": "^0.12.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4"
  }
}
