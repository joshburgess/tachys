{
  "manifest_version": 3,
  "name": "Tachys DevTools",
  "version": "0.0.1",
  "description": "Chrome DevTools extension for inspecting Tachys component trees, hooks state, and re-render highlighting.",
  "devtools_page": "devtools.html",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
