{
  "name": "tachys-aeon",
  "version": "0.1.0",
  "description": "Aeon FRP integration for Tachys - reactive Behaviors and Events as first-class UI primitives",
  "license": "MIT OR Apache-2.0",
  "author": "Josh Burgess",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshburgess/tachys.git",
    "directory": "packages/tachys-aeon"
  },
  "homepage": "https://github.com/joshburgess/tachys/tree/main/packages/tachys-aeon#readme",
  "bugs": {
    "url": "https://github.com/joshburgess/tachys/issues"
  },
  "keywords": ["tachys", "aeon", "frp", "reactive", "hooks", "behavior", "event"],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "LICENSE-MIT", "LICENSE-APACHE"],
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test",
    "build": "rm -rf dist && rollup -c rollup.config.mjs && tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.cts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "tachys": ">=0.1.0",
    "aeon-core": ">=0.0.1",
    "aeon-types": ">=0.0.1",
    "aeon-scheduler": ">=0.0.1"
  },
  "devDependencies": {
    "tachys": "workspace:*",
    "aeon-core": "latest",
    "aeon-types": "latest",
    "aeon-scheduler": "latest",
    "jsdom": "^26.0.0",
    "rollup": "^4.28.0",
    "rollup-plugin-swc3": "^0.12.1",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
