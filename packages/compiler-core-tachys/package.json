{
  "name": "compiler-core-tachys",
  "version": "0.0.1",
  "description": "Portable IR, typed JS emission DSL, and string emitter shared by the Babel and SWC Tachys compilers",
  "license": "MIT",
  "author": "Josh Burgess",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && rollup -c rollup.config.mjs && tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.cts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.0",
    "rollup": "^4.28.0",
    "rollup-plugin-swc3": "^0.12.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
