{
  "name": "babel-plugin-tachys",
  "version": "0.0.1",
  "description": "Babel plugin that compiles Tachys JSX components into markCompiled + cloneNode templates",
  "license": "MIT",
  "author": "Josh Burgess",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && rollup -c rollup.config.mjs && tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.cts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@babel/core": "^7.20.0"
  },
  "dependencies": {
    "@babel/helper-plugin-utils": "^7.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/plugin-syntax-jsx": "^7.24.0",
    "@babel/types": "^7.24.0",
    "@types/babel__core": "^7.20.0",
    "@types/babel__helper-plugin-utils": "^7.10.0",
    "rollup": "^4.28.0",
    "rollup-plugin-swc3": "^0.12.1",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
