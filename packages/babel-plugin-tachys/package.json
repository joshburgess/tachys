{
  "name": "babel-plugin-tachys",
  "version": "0.1.0",
  "description": "Babel plugin that compiles Tachys JSX components into markCompiled + cloneNode templates",
  "license": "MIT OR Apache-2.0",
  "author": "Josh Burgess",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshburgess/tachys.git",
    "directory": "packages/babel-plugin-tachys"
  },
  "homepage": "https://github.com/joshburgess/tachys/tree/main/packages/babel-plugin-tachys#readme",
  "bugs": {
    "url": "https://github.com/joshburgess/tachys/issues"
  },
  "keywords": ["babel-plugin", "tachys", "jsx", "compiler", "vdom", "templates", "performance"],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "LICENSE-MIT", "LICENSE-APACHE"],
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test",
    "build": "rm -rf dist && rollup -c rollup.config.mjs && tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.cts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@babel/core": "^7.20.0"
  },
  "dependencies": {
    "@babel/generator": "^7.24.0",
    "@babel/helper-plugin-utils": "^7.20.0",
    "@babel/parser": "^7.24.0",
    "@babel/plugin-syntax-jsx": "^7.24.0",
    "compiler-core-tachys": "workspace:*"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/types": "^7.24.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@types/babel__core": "^7.20.0",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__helper-plugin-utils": "^7.10.0",
    "jsdom": "^26.0.0",
    "rollup": "^4.28.0",
    "rollup-plugin-swc3": "^0.12.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
