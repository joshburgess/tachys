{
  "name": "swc-plugin-tachys",
  "version": "0.1.0",
  "description": "SWC-based JSX compiler for Tachys. Produces the same CompiledIR and emitted output as babel-plugin-tachys, but parses via @swc/core so SWC-based toolchains (Vite, Next.js, Bun) can use the Tachys fast path without Babel.",
  "license": "MIT OR Apache-2.0",
  "author": "Josh Burgess",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshburgess/tachys.git",
    "directory": "packages/swc-plugin-tachys"
  },
  "homepage": "https://github.com/joshburgess/tachys/tree/main/packages/swc-plugin-tachys#readme",
  "bugs": {
    "url": "https://github.com/joshburgess/tachys/issues"
  },
  "keywords": [
    "swc",
    "swc-plugin",
    "tachys",
    "jsx",
    "compiler",
    "vdom",
    "templates",
    "performance"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "LICENSE-MIT", "LICENSE-APACHE"],
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test",
    "build": "rm -rf dist && rollup -c rollup.config.mjs && tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.cts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@swc/core": "^1.9.0"
  },
  "dependencies": {
    "@swc/types": "^0.1.17",
    "compiler-core-tachys": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@swc/core": "^1.9.0",
    "rollup": "^4.28.0",
    "rollup-plugin-swc3": "^0.12.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
